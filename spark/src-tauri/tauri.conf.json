{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Spark",
  "version": "0.1.0",
  "identifier": "com.spark.notes",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "overlay",
        "title": "Spark",
        "width": 620,
        "height": 460,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "center": true,
        "shadow": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      },
      {
        "label": "library",
        "title": "Spark — Notes",
        "width": 960,
        "height": 640,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "visible": false,
        "center": true,
        "minWidth": 720,
        "minHeight": 480
      },
      {
        "label": "toast",
        "title": "",
        "width": 300,
        "height": 64,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}