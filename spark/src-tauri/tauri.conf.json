{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Spark",
  "version": "0.2.0",
  "identifier": "com.spark.notes",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "overlay",
        "title": "Spark",
        "width": 620,
        "height": 460,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "center": true,
        "shadow": false
      },
      {
        "label": "library",
        "title": "Spark — Notes",
        "width": 960,
        "height": 640,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "visible": false,
        "center": true,
        "minWidth": 720,
        "minHeight": 480
      },
      {
        "label": "toast",
        "title": "",
        "width": 300,
        "height": 64,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Danil",
    "homepage": "https://github.com/NiceTryJony/Spark---Notion",
    "category": "Productivity",
    "shortDescription": "Quick capture desktop app for thoughts and ideas",
    "longDescription": "Spark is a lightning-fast desktop app for capturing thoughts, ideas, and tasks. One hotkey, one input field, one Enter. 100% local, no cloud, no account required. Features auto-tagging, full-text search, and local network sync.",
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "copyright": "Copyright (c) 2026 Danil",
    
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "tsp": false,
      "wix": {
        "language": "en-US",
        "template": null,
        "fragmentPaths": [],
        "componentRefs": [],
        "featureGroupRefs": [],
        "featureRefs": [],
        "mergeRefs": [],
        "skipWebviewInstall": false,
        "enableElevatedUpdateTask": true,
        "bannerPath": null,
        "dialogImagePath": null
      },
      "nsis": {
        "headerImage": null,
        "sidebarImage": null,
        "installerIcon": null,
        "installMode": "perUser",
        "languages": ["English"],
        "displayLanguageSelector": false,
        "compressionLevel": "high",
        "customLanguageFiles": {},
        "template": null,
        "startMenuFolder": "Spark"
      }
    },
    
    "macOS": {
      "minimumSystemVersion": "10.13",
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null,
      "hardenedRuntime": true,
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "background": null,
        "backgroundColorDark": null,
        "backgroundColor": "#f5f5f5"
      }
    },
    
    "linux": {
      "deb": {
        "depends": [],
        "files": {},
        "desktopTemplate": null,
        "section": "misc",
        "priority": "optional"
      },
      "appimage": {
        "bundleMediaFramework": false,
        "files": {}
      }
    }
  }
}